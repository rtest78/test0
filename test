# COMPLETE ONE-CELL CODE
# - ClassPack-safe
# - All model-related imports are inside the class
# - Case-insensitive input mapping in the best way
# - Replaces only null-like values for configured fields
# - Returns prediction only (best for ClassPack)
# - Processed input available in wrapped.last_processed
# - Replaced columns available in wrapped.last_replaced
# ============================================================

class LightGBMWrapper:

    def __init__(self, model_path):
        import lightgbm as lgb

        self.booster = lgb.Booster(model_file=model_path)

        raw_feature_names = self.booster.feature_name()
        if raw_feature_names and raw_feature_names[0] != "Column_0":
            self.feature_names = raw_feature_names
        else:
            n = self.booster.num_feature()
            self.feature_names = [f"feature_{i}" for i in range(n)]

        # Defaults for fields that need replacement when input is null-like
        self.default_map = {
            "clear_early_risk_score": 300,
            "loan_purpose": 1,
            "AU8220": -1,
            "ALL0400": 99,
            "ALL4018": 0,
            "ALL4520": 0,
            "ALL7120": 999,
            "ALL7517": 999,
            "ALL8020": 0,
            "ALL8183": 0,
            "ALL8220": 9999,
            "ALL8225": 0,
            "ALL8320": 0,
            "ALM5072": 999999999,
            "ALM6280": 999,
            "ALS5400": 0,
            "ALX8220": 9999,
            "BCA7300": 999,
            "BCA8370": -1,
            "BCC5520": -1,
            "BCN8220": -1,
            "BCX7110": 999,
            "CRU8320": 0,
            "ILN8320": 9999,
            "IQF9510": 0,
            "IQT9425": 90,
            "IQT9426": 90,
            "IQT9510": 0,
        }

        # Best approach:
        # map lowercased input names directly to exact model feature names
        self.feature_name_map = {str(f).strip().lower(): f for f in self.feature_names}
        self.default_map_lower = {str(k).strip().lower(): v for k, v in self.default_map.items()}

        # Debug fields
        self.last_processed = None
        self.last_replaced = []

    def preprocess(self, X):
        import pandas as pd
        import numpy as np

        # Convert input to DataFrame
        if isinstance(X, dict):
            X = pd.DataFrame([X])
        elif isinstance(X, list):
            X = pd.DataFrame(X)
        elif not isinstance(X, pd.DataFrame):
            X = pd.DataFrame(X)

        X = X.copy()

        # --------------------------------------------------------
        # BEST WAY:
        # map input columns directly to exact model feature names
        # --------------------------------------------------------
        X = X.rename(
            columns=lambda c: self.feature_name_map.get(str(c).strip().lower(), c)
        )

        # Normalize null-like values
        X = X.replace(["", " ", "NULL", "null", "None"], np.nan)

        replaced_columns = []

        # Add missing configured fields with defaults
        for feature_lower, default_value in self.default_map_lower.items():
            feature = self.feature_name_map.get(feature_lower, feature_lower)
            if feature not in X.columns:
                X[feature] = default_value

        # Replace null-like values only for configured fields
        for feature_lower, default_value in self.default_map_lower.items():
            feature = self.feature_name_map.get(feature_lower, feature_lower)
            if feature in X.columns:
                if X[feature].isna().any():
                    replaced_columns.append(feature)
                X[feature] = X[feature].fillna(default_value)

        # Ensure all model features exist
        for feature in self.feature_names:
            if feature not in X.columns:
                X[feature] = np.nan

        # Enforce exact model feature order
        X = X[self.feature_names]

        # Save debug info
        self.last_processed = X.copy()
        self.last_replaced = replaced_columns

        return X

    def predict(self, X):
        import pandas as pd
        import numpy as np

        X_processed = self.preprocess(X)
        raw = self.booster.predict(X_processed)

        if isinstance(raw, np.ndarray) and raw.ndim == 1:
            out = pd.DataFrame(raw, columns=["output"])
        else:
            out = pd.DataFrame(
                raw,
                columns=[f"output_{i}" for i in range(raw.shape[1])]
            )

        out = out.reset_index(drop=True)
        out.columns = [str(c) for c in out.columns]
        return out


