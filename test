        # Model feature names
        # ------------------------------------------------------------
        raw_feature_names = self.booster.feature_name()

        if raw_feature_names and len(raw_feature_names) > 0 and str(raw_feature_names[0]).strip().lower() != "column_0":
            self.model_feature_names = [str(c).strip() for c in raw_feature_names]
        else:
            n = self.booster.num_feature()
            self.model_feature_names = [f"feature_{i}" for i in range(n)]

        # Keep this also, since some of your other code uses feature_names
        self.feature_names = self.model_feature_names
