<xsl:when test="name() = 'CounterOfferReasonList' and counterOfferReason[*[normalize-space()]]">
    <xsl:text>[</xsl:text>

    <xsl:for-each select="counterOfferReason[*[normalize-space()]]">
        <xsl:text>{</xsl:text>

        <xsl:call-template name="process-children">
            <xsl:with-param name="nodes" select="*" />
        </xsl:call-template>

        <xsl:text>}</xsl:text>

        <xsl:if test="position() != last()">
            <xsl:text>,</xsl:text>
        </xsl:if>
    </xsl:for-each>

    <xsl:text>]</xsl:text>
</xsl:when>
