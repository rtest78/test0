 def preprocess(self, X):
        if isinstance(X, dict):
            X = pd.DataFrame([X])
        elif isinstance(X, list):
            X = pd.DataFrame(X)
        elif not isinstance(X, pd.DataFrame):
            X = pd.DataFrame(X)

        X = X.copy()
        X.columns = [str(col).strip().lower() for col in X.columns]

        X = X.replace(["", " ", "NULL", "null", "None"], np.nan)

        for col in X.columns:
            if X[col].dtype == "object":
                X[col] = X[col].replace(["", " ", "NULL", "null", "None"], np.nan)

        replaced_columns = []

        for feature_lower, default_value in self.default_map_lower.items():
            if feature_lower not in X.columns:
                X[feature_lower] = default_value

        for feature_lower, default_value in self.default_map_lower.items():
            if feature_lower in X.columns:
                if X[feature_lower].isna().any():
                    replaced_columns.append(feature_lower)
                X[feature_lower] = X[feature_lower].fillna(default_value)

        for feature_lower in self.feature_name_map:
            if feature_lower not in X.columns:
                X[feature_lower] = np.nan

        X = X.rename(columns=self.feature_name_map)
        X = X[self.feature_names]

        replaced_columns_original = [
            self.feature_name_map.get(col, col) if col in self.feature_name_map
            else next((k for k in self.default_map if k.lower() == col), col)
            for col in replaced_columns
        ]

        return X, replaced_columns_original

    def predict(self, X, feature_names=None):
        X_processed, replaced_columns = self.preprocess(X)
        raw = self.booster.predict(X_processed)

        if isinstance(raw, np.ndarray) and raw.ndim == 1:
            pred_df = pd.DataFrame(raw, columns=["output"])
        else:
            pred_df = pd.DataFrame(
                raw,
                columns=[f"output_{i}" for i in range(raw.shape[1])]
            )

        result_df = pd.concat(
            [X_processed.reset_index(drop=True), pred_df.reset_index(drop=True)],
            axis=1
        )

        self.last_processed = X_processed
        self.last_replaced = replaced_columns

        return result_df
