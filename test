package com.example.jsonviewer;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import jakarta.servlet.http.HttpSession;
import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.multipart.MultipartFile;

import java.io.BufferedReader;
import java.io.InputStreamReader;
import java.io.Serializable;
import java.nio.charset.StandardCharsets;
import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;
import java.util.Map;

@SpringBootApplication
@Controller
public class JsonViewerApplication {

    private final ObjectMapper mapper = new ObjectMapper();

    public static void main(String[] args) {
        SpringApplication.run(JsonViewerApplication.class, args);
    }

    @GetMapping("/")
    public String home(Model model) {
        model.addAttribute("recordCount", 0);
        model.addAttribute("inputRows", new ArrayList<FieldRow>());
        model.addAttribute("outputRows", new ArrayList<FieldRow>());
        return "index";
    }

    @PostMapping("/upload")
    public String uploadFile(@RequestParam("file") MultipartFile file,
                             HttpSession session,
                             Model model) {

        if (file == null || file.isEmpty()) {
            model.addAttribute("errorMessage", "Please select a file.");
            model.addAttribute("recordCount", 0);
            model.addAttribute("inputRows", new ArrayList<FieldRow>());
            model.addAttribute("outputRows", new ArrayList<FieldRow>());
            return "index";
        }

        try {
            List<MemberRecord> records = parseFile(file);
            session.setAttribute("records", records);

            model.addAttribute("successMessage", "File uploaded successfully. Records loaded: " + records.size());
            model.addAttribute("recordCount", records.size());
            model.addAttribute("inputRows", new ArrayList<FieldRow>());
            model.addAttribute("outputRows", new ArrayList<FieldRow>());

        } catch (Exception ex) {
            model.addAttribute("errorMessage", "Error reading file: " + ex.getMessage());
            model.addAttribute("recordCount", 0);
            model.addAttribute("inputRows", new ArrayList<FieldRow>());
            model.addAttribute("outputRows", new ArrayList<FieldRow>());
        }

        return "index";
    }

    @PostMapping("/search")
    public String searchAccount(@RequestParam("accountNumber") String accountNumber,
                                HttpSession session,
                                Model model) {

        List<MemberRecord> records = (List<MemberRecord>) session.getAttribute("records");

        if (records == null || records.isEmpty()) {
            model.addAttribute("errorMessage", "Please upload a file first.");
            model.addAttribute("recordCount", 0);
            model.addAttribute("inputRows", new ArrayList<FieldRow>());
            model.addAttribute("outputRows", new ArrayList<FieldRow>());
            return "index";
        }

        MemberRecord matchedRecord = searchByAccountNumber(records, accountNumber);

        if (matchedRecord == null) {
            model.addAttribute("errorMessage", "No record found for account number: " + accountNumber);
            model.addAttribute("recordCount", records.size());
            model.addAttribute("searchedAccountNumber", accountNumber);
            model.addAttribute("inputRows", new ArrayList<FieldRow>());
            model.addAttribute("outputRows", new ArrayList<FieldRow>());
            return "index";
        }

        List<FieldRow> inputRows = flattenJson(matchedRecord.inputJson);
        List<FieldRow> outputRows = flattenJson(matchedRecord.outputJson);

        model.addAttribute("successMessage", "Record found for account number: " + accountNumber);
        model.addAttribute("recordCount", records.size());
        model.addAttribute("searchedAccountNumber", accountNumber);
        model.addAttribute("memberNumber", matchedRecord.memberNumber);
        model.addAttribute("inputRows", inputRows);
        model.addAttribute("outputRows", outputRows);

        return "index";
    }

    private List<MemberRecord> parseFile(MultipartFile file) {
        List<MemberRecord> records = new ArrayList<>();

        try (BufferedReader reader = new BufferedReader(
                new InputStreamReader(file.getInputStream(), StandardCharsets.UTF_8))) {

            String line;
            int lineNumber = 0;

            while ((line = reader.readLine()) != null) {
                lineNumber++;

                if (line.trim().isEmpty()) {
                    continue;
                }

                try {
                    MemberRecord record = parseLine(line);

                    if (record != null) {
                        records.add(record);
                    }

                } catch (Exception ex) {
                    System.out.println("Skipping line " + lineNumber + ": " + ex.getMessage());
                }
            }

        } catch (Exception ex) {
            throw new RuntimeException("Error reading uploaded file: " + ex.getMessage(), ex);
        }

        return records;
    }

    private MemberRecord parseLine(String line) throws Exception {

        /*
         Example line:
         2026-06-09, {"input":{"type":"java.lang.String","data":"{...}"},"output":{"type":"java.lang.String","data":"{...}"}}

         We remove everything before the first {
        */

        int jsonStart = line.indexOf("{");

        if (jsonStart < 0) {
            return null;
        }

        String outerJsonText = line.substring(jsonStart).trim();

        JsonNode outerJson = mapper.readTree(outerJsonText);

        JsonNode inputDataNode = outerJson.path("input").path("data");
        JsonNode outputDataNode = outerJson.path("output").path("data");

        JsonNode inputJson = parseInnerJson(inputDataNode);
        JsonNode outputJson = parseInnerJson(outputDataNode);

        String accountNumber = findFirstValueByFieldName(inputJson, "accountNumber");
        String memberNumber = findFirstValueByFieldName(inputJson, "memberNumber");

        return new MemberRecord(accountNumber, memberNumber, inputJson, outputJson);
    }

    private JsonNode parseInnerJson(JsonNode dataNode) throws Exception {

        if (dataNode == null || dataNode.isMissingNode() || dataNode.isNull()) {
            return mapper.createObjectNode();
        }

        /*
         In your file, input.data and output.data are JSON strings.
         Example:
         "data":"{\"collections\":{\"request\":{...}}}"
        */

        if (dataNode.isTextual()) {
            String jsonText = dataNode.asText();

            if (jsonText == null || jsonText.trim().isEmpty()) {
                return mapper.createObjectNode();
            }

            return mapper.readTree(jsonText);
        }

        return dataNode;
    }

    private MemberRecord searchByAccountNumber(List<MemberRecord> records, String accountNumber) {

        if (accountNumber == null || accountNumber.trim().isEmpty()) {
            return null;
        }

        String searchValue = accountNumber.trim();

        for (MemberRecord record : records) {
            if (containsFieldValue(record.inputJson, "accountNumber", searchValue)) {
                return record;
            }
        }

        return null;
    }

    private boolean containsFieldValue(JsonNode node, String fieldName, String expectedValue) {

        if (node == null) {
            return false;
        }

        if (node.isObject()) {
            Iterator<Map.Entry<String, JsonNode>> fields = node.fields();

            while (fields.hasNext()) {
                Map.Entry<String, JsonNode> field = fields.next();

                String currentFieldName = field.getKey();
                JsonNode currentValue = field.getValue();

                if (currentFieldName.equalsIgnoreCase(fieldName)
                        && currentValue != null
                        && expectedValue.equalsIgnoreCase(currentValue.asText())) {
                    return true;
                }

                if (containsFieldValue(currentValue, fieldName, expectedValue)) {
                    return true;
                }
            }
        }

        if (node.isArray()) {
            for (JsonNode child : node) {
                if (containsFieldValue(child, fieldName, expectedValue)) {
                    return true;
                }
            }
        }

        return false;
    }

    private List<FieldRow> flattenJson(JsonNode jsonNode) {
        List<FieldRow> rows = new ArrayList<>();
        flatten(jsonNode, "", rows);
        return rows;
    }

    private void flatten(JsonNode node, String path, List<FieldRow> rows) {

        if (node == null || node.isNull()) {
            rows.add(new FieldRow(path, "null"));
            return;
        }

        if (node.isValueNode()) {
            rows.add(new FieldRow(path, node.asText()));
            return;
        }

        if (node.isObject()) {
            Iterator<Map.Entry<String, JsonNode>> fields = node.fields();

            while (fields.hasNext()) {
                Map.Entry<String, JsonNode> field = fields.next();

                String newPath = path.isEmpty()
                        ? field.getKey()
                        : path + "." + field.getKey();

                flatten(field.getValue(), newPath, rows);
            }
        }

        if (node.isArray()) {
            int index = 0;

            for (JsonNode child : node) {
                String newPath = path + "[" + index + "]";
                flatten(child, newPath, rows);
                index++;
            }
        }
    }

    private String findFirstValueByFieldName(JsonNode node, String fieldName) {

        if (node == null) {
            return null;
        }

        if (node.isObject()) {
            Iterator<Map.Entry<String, JsonNode>> fields = node.fields();

            while (fields.hasNext()) {
                Map.Entry<String, JsonNode> field = fields.next();

                if (field.getKey().equalsIgnoreCase(fieldName)) {
                    return field.getValue().asText();
                }

                String value = findFirstValueByFieldName(field.getValue(), fieldName);

                if (value != null) {
                    return value;
                }
            }
        }

        if (node.isArray()) {
            for (JsonNode child : node) {
                String value = findFirstValueByFieldName(child, fieldName);

                if (value != null) {
                    return value;
                }
            }
        }

        return null;
    }

    public static class FieldRow implements Serializable {

        private String fieldPath;
        private String value;

        public FieldRow() {
        }

        public FieldRow(String fieldPath, String value) {
            this.fieldPath = fieldPath;
            this.value = value;
        }

        public String getFieldPath() {
            return fieldPath;
        }

        public void setFieldPath(String fieldPath) {
            this.fieldPath = fieldPath;
        }

        public String getValue() {
            return value;
        }

        public void setValue(String value) {
            this.value = value;
        }
    }

    public static class MemberRecord implements Serializable {

        private String accountNumber;
        private String memberNumber;
        private JsonNode inputJson;
        private JsonNode outputJson;

        public MemberRecord() {
        }

        public MemberRecord(String accountNumber, String memberNumber, JsonNode inputJson, JsonNode outputJson) {
            this.accountNumber = accountNumber;
            this.memberNumber = memberNumber;
            this.inputJson = inputJson;
            this.outputJson = outputJson;
        }

        public String getAccountNumber() {
            return accountNumber;
        }

        public void setAccountNumber(String accountNumber) {
            this.accountNumber = accountNumber;
        }

        public String getMemberNumber() {
            return memberNumber;
        }

        public void setMemberNumber(String memberNumber) {
            this.memberNumber = memberNumber;
        }

        public JsonNode getInputJson() {
            return inputJson;
        }

        public void setInputJson(JsonNode inputJson) {
            this.inputJson = inputJson;
        }

        public JsonNode getOutputJson() {
            return outputJson;
        }

        public void setOutputJson(JsonNode outputJson) {
            this.outputJson = outputJson;
        }
    }
}
