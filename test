class LightGBMWrapper:
    def __init__(self, model_path):
        import lightgbm as lgb

        self.booster = lgb.Booster(model_file=model_path)

        raw_feature_names = self.booster.feature_name()
        if raw_feature_names and raw_feature_names[0] != "Column_0":
            self.feature_names = raw_feature_names
        else:
            self.feature_names = [f"feature_{i}" for i in range(self.booster.num_feature())]

        self.missing_imputation_map = {
            "CCA_AMT_OF_LOANS_PD_OFF": 99999999999,
            "CCA_CCA_INQ_180_DAYS": -1,
            "CCA_CCI_INQ_3_YRS": -1,
            "CCA_NUM_BANKACCTS": -1,
            "CCA_RPT_NMI_PRV_SEEN": 99999999999,
            "FA_INQ_365_DAYS": -1,
            "ALL4018": 999,
            "ALL4520": 99,
            "ALL7120": 999,
            "ALL7320": 999,
            "ALL7519": 999,
            "ALL7938": 999,
            "ALL8020": 999999,
            "ALL8150": 9999,
            "ALL8183": 9999,
            "ALL8321": 9999,
            "T11_TUPL1705": 999999999,
        }

        self.default_replacement_map = {
            "ALL4018": {999: -1},
            "ALL4520": {99: -1},
            "ALL7938": {994: -1, 997: -2, 999: -3},
            "ALL8020": {999994: -1, 999996: -2, 999999: -3},
            "ALL8150": {9996: 50, 9999: -2},
            "ALL8183": {9999: -2},
            "ALL8321": {9999: -3, 9996: -2, 9994: -1},
        }

        self.derived_feature_map = {
            "T11_TBCA3303_ABS": "T11_TBCA3303",
            "T11_TBCC1303_ABS": "T11_TBCC1303",
            "T11_TBCC2303_ABS": "T11_TBCC2303",
            "T11_TREV0384_ABS": "T11_TREV0384",
            "T11_TREV0385_ABS": "T11_TREV0385",
        }

    def preprocess(self, X, feature_names=None):
        import pandas as pd
        import numpy as np

        if feature_names is None:
            feature_names = self.feature_names

        if isinstance(X, dict):
            X = pd.DataFrame([X])
        elif isinstance(X, list):
            X = pd.DataFrame(X)
        elif isinstance(X, np.ndarray):
            X = pd.DataFrame(X)
        elif not isinstance(X, pd.DataFrame):
            X = pd.DataFrame(X)

        X = X.copy()

        input_col_map = {str(col).strip().lower(): col for col in X.columns}

        rename_map = {}
        for model_col in feature_names:
            key = str(model_col).strip().lower()
            if key in input_col_map:
                rename_map[input_col_map[key]] = model_col

        X = X.rename(columns=rename_map)

        X = X.replace(["", " ", "NULL", "null", "None", "none"], np.nan)

        for col in X.columns:
            X[col] = pd.to_numeric(X[col], errors="ignore")

        # Step 1: Missing imputation
        for col, impute_val in self.missing_imputation_map.items():
            if col in X.columns:
                X[col] = X[col].fillna(impute_val)

        # Step 2: Default value replacement
        for col, replacement_map in self.default_replacement_map.items():
            if col in X.columns:
                X[col] = X[col].replace(replacement_map)

        # Step 3: Derived ABS features
        for derived_col, source_col in self.derived_feature_map.items():
            if derived_col in feature_names:
                if source_col in X.columns:
                    X[derived_col] = X[source_col].abs()
                else:
                    raise ValueError(
                        f"Model requires '{derived_col}', but source column "
                        f"'{source_col}' is missing from input."
                    )

        # Step 4: Derived paid-off loan amount feature
        if "CCA_AMT_OF_LOANS_PD_OFF_0" in feature_names:
            if "CCA_AMT_OF_LOANS_PD_OFF" in X.columns:
                X["CCA_AMT_OF_LOANS_PD_OFF_0"] = X["CCA_AMT_OF_LOANS_PD_OFF"].apply(
                    lambda x: 4500 if x == 0 else x
                )
            else:
                raise ValueError(
                    "Model requires 'CCA_AMT_OF_LOANS_PD_OFF_0', but source "
                    "column 'CCA_AMT_OF_LOANS_PD_OFF' is missing from input."
                )

        for col in feature_names:
            if col not in X.columns:
                X[col] = 0

        return X[feature_names]

    def predict(self, X, feature_names=None):
        import pandas as pd
        import numpy as np

        if feature_names is None:
            feature_names = self.feature_names

        X_processed = self.preprocess(X, feature_names)

        probability = np.asarray(self.booster.predict(X_processed))
        probability = np.clip(probability, 1e-15, 1 - 1e-15)

        score = 480 + (30 / np.log(2)) * np.log((1 - probability) / probability)
        score2 = np.round(score)

        final_score = np.where(
            score2 > 850,
            850,
            np.where(score2 < 300, 300, score2)
        ).astype(int)

        pred_df = pd.DataFrame({
            "probability": probability,
            "score": final_score
        })

        return pd.concat(
            [X_processed.reset_index(drop=True), pred_df.reset_index(drop=True)],
            axis=1
        )
