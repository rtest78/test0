<!-- Remove empty SentiLinkScoresResponse -->
<xsl:template match="SentiLinkScoresResponse[
    not(*) and not(@*) and not(normalize-space(.))
]"/>

<!-- Remove empty SentiLinkECBSVResponse -->
<xsl:template match="SentiLinkECBSVResponse[
    not(*) and not(@*) and not(normalize-space(.))
]"/>

<!-- Remove parent when both responses are empty or missing -->
<xsl:template match="SentiLinkResponse[
    not(SentiLinkScoresResponse[* or @* or normalize-space(.)])
    and
    not(SentiLinkECBSVResponse[* or @* or normalize-space(.)])
]"/>
