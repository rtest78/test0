<!-- Process SentiLinkResponse only when at least one response has data -->
<xsl:if test="$nodes[
    name() = 'SentiLinkResponse'
    and
    (
        SentiLinkScoresResponse[
            * or @* or normalize-space(.)
        ]
        or
        SentiLinkECBSVResponse[
            * or @* or normalize-space(.)
        ]
    )
]">

    <xsl:text>"SentiLinkResponse": {</xsl:text>

    <!-- Include Scores response only when it has data -->
    <xsl:if test="$nodes[
        name() = 'SentiLinkResponse'
    ]/SentiLinkScoresResponse[
        * or @* or normalize-space(.)
    ]">

        <xsl:text>"SentiLinkScoresResponse": </xsl:text>

        <xsl:apply-templates
            select="$nodes[
                name() = 'SentiLinkResponse'
            ]/SentiLinkScoresResponse[
                * or @* or normalize-space(.)
            ]"/>
    </xsl:if>

    <!-- Add comma only when both responses have data -->
    <xsl:if test="
        $nodes[name() = 'SentiLinkResponse']
            /SentiLinkScoresResponse[
                * or @* or normalize-space(.)
            ]
        and
        $nodes[name() = 'SentiLinkResponse']
            /SentiLinkECBSVResponse[
                * or @* or normalize-space(.)
            ]
    ">
        <xsl:text>,</xsl:text>
    </xsl:if>

    <!-- Include ECBSV response only when it has data -->
    <xsl:if test="$nodes[
        name() = 'SentiLinkResponse'
    ]/SentiLinkECBSVResponse[
        * or @* or normalize-space(.)
    ]">

        <xsl:text>"SentiLinkECBSVResponse": </xsl:text>

        <xsl:apply-templates
            select="$nodes[
                name() = 'SentiLinkResponse'
            ]/SentiLinkECBSVResponse[
                * or @* or normalize-space(.)
            ]"/>
    </xsl:if>

    <xsl:text>}</xsl:text>

    <!-- Add comma when other objects follow -->
    <xsl:if test="$nodes[
        name() != 'SentiLinkResponse'
    ]">
        <xsl:text>,</xsl:text>
    </xsl:if>

</xsl:if>
