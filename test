<xsl:when test="name() = 'SentiLinkResponse'">
    <xsl:text>{</xsl:text>

    <xsl:if test="SentiLinkScoresResponse[
            * or @* or normalize-space(translate(., '&quot;', ''))
        ]">

        <xsl:text>"SentiLinkScoresResponse": </xsl:text>
        <xsl:apply-templates select="SentiLinkScoresResponse"/>

        <xsl:if test="SentiLinkECBSVResponse[
                * or @* or normalize-space(translate(., '&quot;', ''))
            ]">
            <xsl:text>,</xsl:text>
        </xsl:if>

    </xsl:if>

    <xsl:if test="SentiLinkECBSVResponse[
            * or @* or normalize-space(translate(., '&quot;', ''))
        ]">

        <xsl:text>"SentiLinkECBSVResponse": </xsl:text>
        <xsl:apply-templates select="SentiLinkECBSVResponse"/>

    </xsl:if>

    <xsl:text>}</xsl:text>
</xsl:when>
