# ============================================================
# ONE-CELL, CLASS-PACK-SAFE VERSION
# - All imports used by the model are inside the class methods
# - predict() returns ONLY prediction output (stable for ClassPack)
# - processed input is available in wrapped.last_processed
# - replaced columns are available in wrapped.last_replaced
# ============================================================

class LightGBMWrapper:

    def __init__(self, model_path):
        import lightgbm as lgb

        self.booster = lgb.Booster(model_file=model_path)

        raw_feature_names = self.booster.feature_name()
        if raw_feature_names and raw_feature_names[0] != "Column_0":
            self.feature_names = raw_feature_names
        else:
            n = self.booster.num_feature()
            self.feature_names = [f"feature_{i}" for i in range(n)]

        # Hardcoded defaults
        self.default_map = {
            "clear_early_risk_score": 300,
            "loan_purpose": 1,
            "AU8220": -1,
            "ALL0400": 99,
            "ALL4018": 0,
            "ALL4520": 0,
            "ALL7120": 999,
            "ALL7517": 999,
            "ALL8020": 0,
            "ALL8183": 0,
            "ALL8220": 9999,
            "ALL8225": 0,
            "ALL8320": 0,
            "ALM5072": 999999999,
            "ALM6280": 999,
            "ALS5400": 0,
            "ALX8220": 9999,
            "BCA7300": 999,
            "BCA8370": -1,
            "BCC5520": -1,
            "BCN8220": -1,
            "BCX7110": 999,
            "CRU8320": 0,
            "ILN8320": 9999,
            "IQF9510": 0,
            "IQT9425": 90,
            "IQT9426": 90,
            "IQT9510": 0,
        }

        self.feature_name_map = {f.lower(): f for f in self.feature_names}
        self.default_map_lower = {k.lower(): v for k, v in self.default_map.items()}

        # Debug holders
        self.last_processed = None
        self.last_replaced = []

    def preprocess(self, X):
        import pandas as pd
        import numpy as np

        if isinstance(X, dict):
            X = pd.DataFrame([X])
        elif isinstance(X, list):
            X = pd.DataFrame(X)
        elif not isinstance(X, pd.DataFrame):
            X = pd.DataFrame(X)

        X = X.copy()

        # Make input columns case-insensitive
        X.columns = [str(col).strip().lower() for col in X.columns]

        # Normalize null-like values
        X = X.replace(["", " ", "NULL", "null", "None"], np.nan)

        replaced_columns = []

        # Add missing configured columns with defaults
        for feature_lower, default_value in self.default_map_lower.items():
            if feature_lower not in X.columns:
                X[feature_lower] = default_value

        # Replace null-like values only for configured fields
        for feature_lower, default_value in self.default_map_lower.items():
            if feature_lower in X.columns:
                if X[feature_lower].isna().any():
                    replaced_columns.append(feature_lower)
                X[feature_lower] = X[feature_lower].fillna(default_value)

        # Ensure all model features exist
        for feature_lower in self.feature_name_map:
            if feature_lower not in X.columns:
                X[feature_lower] = np.nan

        # Rename back to exact model feature names
        X = X.rename(columns=self.feature_name_map)

        # Enforce exact model feature order
        X = X[self.feature_names]

        # Store debug info
        replaced_columns_original = [
            self.feature_name_map.get(col, col)
            if col in self.feature_name_map
            else next((k for k in self.default_map if k.lower() == col), col)
            for col in replaced_columns
        ]

        self.last_processed = X.copy()
        self.last_replaced = replaced_columns_original

        return X

    def predict(self, X):
        import pandas as pd
        import numpy as np

        X_processed = self.preprocess(X)
        raw = self.booster.predict(X_processed)

        if isinstance(raw, np.ndarray) and raw.ndim == 1:
            out = pd.DataFrame(raw, columns=["output"])
        else:
            out = pd.DataFrame(
                raw,
                columns=[f"output_{i}" for i in range(raw.shape[1])]
            )

        # Normalize output for stable ClassPack comparison
        out = out.reset_index(drop=True)
        out.columns = [str(c) for c in out.columns]

        return out


