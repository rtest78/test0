# ------------------------------------------------------------
# Internal Clarity flag
#
# If clarity_hit_flag is not part of input, default to no-hit.
# 1 = Clarity hit
# 0 = Clarity no-hit
# ------------------------------------------------------------
clarity_hit_col = self.find_col(X.columns, "clarity_hit_flag")

if clarity_hit_col is None:
    X["_internal_clarity_hit_flag"] = 0
    clarity_hit_col = "_internal_clarity_hit_flag"
else:
    X[clarity_hit_col] = pd.to_numeric(
        X[clarity_hit_col],
        errors="coerce"
    ).fillna(0)

# Only exact 1 means hit. Everything else is no-hit.
X[clarity_hit_col] = X[clarity_hit_col].apply(
    lambda v: 1 if v == 1 else 0
)
